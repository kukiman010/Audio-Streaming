# Copy to livekit.env and fill values.
# This file is auto-loaded by gui_client.py and server.py.

LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=replace_with_long_secret_32_chars_min
LIVEKIT_PAIRING_SECRET=replace_with_random_pairing_secret
LIVEKIT_URL=ws://127.0.0.1:7880
# Публичный URL helper для клиентов с других машин (должен совпадать с тем, что в GUI):
HELPER_URL=http://127.0.0.1:8000
HELPER_HOST=0.0.0.0
HELPER_PORT=8000
# Необязательно: значения по умолчанию в gui_client.py
# LIVEKIT_DEFAULT_ROOM=audio-room
# LIVEKIT_PUBLISHER_IDENTITY=publisher-local
ENABLE_LEGACY_TRANSPORT=0
