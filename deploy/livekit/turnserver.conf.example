listening-port=3478
tls-listening-port=5349
fingerprint
use-auth-secret
static-auth-secret=REPLACE_WITH_TURN_SHARED_SECRET
realm=livekit.example.com
total-quota=100
stale-nonce=600
no-loopback-peers
no-multicast-peers
no-cli
cert=/etc/letsencrypt/live/livekit.example.com/fullchain.pem
pkey=/etc/letsencrypt/live/livekit.example.com/privkey.pem
min-port=50000
max-port=50100
